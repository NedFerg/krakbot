# ============================================================
# KrakBot — Environment Variable Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Kraken API Credentials (required for live trading)
# ------------------------------------------------------------
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ------------------------------------------------------------
# Trading Mode
# Set to "true" to submit real orders; "false" = paper mode.
# ------------------------------------------------------------
ENABLE_LIVE_TRADING=false

# ------------------------------------------------------------
# Capital Configuration
# Change TOTAL_TRADING_CAPITAL to scale the bot automatically.
# $51 → paper testing | $1000 → small live | $5000+ → scaled
# ------------------------------------------------------------
TOTAL_TRADING_CAPITAL=51.0

# Fraction of available capital to deploy per trade (0.0–1.0).
# 0.95 keeps 5% as a buffer to absorb fees and slippage.
POSITION_SIZE_PCT=0.95

# ------------------------------------------------------------
# Risk Manager
# All limits are checked before every order is submitted.
# ------------------------------------------------------------

# Maximum fraction of total capital allocated to one symbol.
# At 0.20 and $1000 capital: max $200 per symbol.
RISK_MAX_POSITION_PCT=0.20

# Maximum USD notional value of a single order.
# Defaults to TOTAL_TRADING_CAPITAL if not set (no cap).
# RISK_MAX_NOTIONAL_PER_ORDER=200.0

# Per-symbol drawdown threshold that halts trading on that symbol.
# 0.15 = stop trading a symbol after 15% loss on a single trade.
RISK_MAX_DRAWDOWN_PCT=0.15

# Portfolio-level drawdown that triggers a global trading halt.
# 0.25 = stop ALL trading if the portfolio is down 25% from peak.
RISK_GLOBAL_MAX_DRAWDOWN_PCT=0.25

# ------------------------------------------------------------
# Bot Loop
# ------------------------------------------------------------

# Seconds between each signal evaluation cycle (default 300 = 5 min).
UPDATE_INTERVAL_SECONDS=300
